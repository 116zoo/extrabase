{
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MedicalBusiness"],
  "@id": "{URL}#business",
  "name": "{BUSINESS_NAME}",
  "url": "{URL}",
  "telephone": "{PHONE}",
  "email": "{EMAIL}",
  "description": "{DESCRIPTION}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{STREET}",
    "addressLocality": "{CITY}",
    "postalCode": "{POSTAL_CODE}",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "{LAT}",
    "longitude": "{LNG}"
  },
  "openingHoursSpecification": [],
  "image": "{IMAGE_URL}",
  "priceRange": "{PRICE_RANGE}",
  "sameAs": []
}
