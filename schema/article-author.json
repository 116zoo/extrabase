{
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": "{URL}#article",
  "headline": "{TITLE}",
  "description": "{DESCRIPTION}",
  "url": "{URL}",
  "datePublished": "{DATE_PUBLISHED}",
  "dateModified": "{DATE_MODIFIED}",
  "author": {
    "@type": "Person",
    "name": "{AUTHOR_NAME}",
    "url": "{AUTHOR_URL}",
    "description": "{AUTHOR_BIO}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{PUBLISHER_NAME}",
    "url": "{PUBLISHER_URL}",
    "logo": {
      "@type": "ImageObject",
      "url": "{LOGO_URL}"
    }
  },
  "image": "{IMAGE_URL}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{URL}"
  }
}
